        path.append(24)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / z > m ** 1.3 + 15):
        path.append(25)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / z > m ** 2 + 8):
        path.append(26)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / z > m * (m - 3) + 15):
        path.append(27)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / z > m * 20 + 15):
        path.append(28)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / z > m * w + 15):
        path.append(29)
    if (x / y + w / z > m ** 2 + 15) != (x / y + w / 4.5 > m ** 2 + 15):
        path.append(30)

    if x / y + w / z > m ** 2 + 15:
        type_code = 'A3'

    path1 = comm.recv(source=1, tag=11, status=status)
    path2 = comm.recv(source=2, tag=21, status=status)
    path3 = comm.recv(source=3, tag=31, status=status)

    return [path, path1, path2, path3]

