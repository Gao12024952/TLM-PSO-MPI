        path.append(10)

    if (x * w) / (y * z + 1) > m * 12 + 8:
        type_code = 'A1'

    if (x ** m / 10000 > y + z + w) != ((x * 2) ** m / 10000 > y + z + w):
        path.append(11)
    if (x ** m / 10000 > y + z + w) != ((x + 50) ** m / 10000 > y + z + w):
        path.append(12)
    if (x ** m / 10000 > y + z + w) != (18 ** m / 10000 > y + z + w):
        path.append(13)
    if (x ** m / 10000 > y + z + w) != (x ** m / 1000 > y + z + w):
        path.append(14)
    if (x ** m / 10000 > y + z + w) != (x ** m / 10000 > y + z + w / 45):
        path.append(15)
    if (x ** m / 10000 > y + z + w) != (x ** m / 10000 > y - z * 12 + w):
        path.append(16)
    if (x ** m / 10000 > y + z + w) != (x ** m / 10000 > -y * 4.8 + z + w):
        path.append(17)
    if (x ** m / 10000 > y + z + w) != (x ** m / 10000 > y + z - w / 5):
        path.append(18)
    if (x ** m / 10000 > y + z + w) != (x ** m / 10000 > y + z + w - 50 * m):
        path.append(19)
    if (x ** m / 10000 > y + z + w) != (x ** m / (10000 - 105 * x) > y + z + w):
        path.append(20)

    if x ** m / 10000 > y + z + w:
        type_code = 'A2'

    if (x / y + w / z > m ** 2 + 15) != (x * 2 / y + w / z > m ** 2 + 15):
        path.append(21)
    if (x / y + w / z > m ** 2 + 15) != ((x + 100) / y + w / z > m ** 2 + 15):
        path.append(22)
