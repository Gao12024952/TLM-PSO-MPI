def generate_mpi_paths(comm, a):
    """主进程与工作进程通信，处理5个变量"""
    status = MPI.Status()
    path = []
    x, y, z, w, m = a[0], a[1], a[2], a[3], a[4]

    comm.send(x, dest=1, tag=1)
    comm.send(y, dest=1, tag=2)
    comm.send(z, dest=1, tag=3)

    comm.send(y, dest=2, tag=1)
    comm.send(z, dest=2, tag=2)
    comm.send(w, dest=2, tag=3)

    comm.send(z, dest=3, tag=1)
    comm.send(w, dest=3, tag=2)
    comm.send(m, dest=3, tag=3)

    # 主进程的路径计算
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((x * 1.5 * w) / (y * z + 1) > m * 12 + 8):
        path.append(1)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((x * (w + 35)) / (y * z + 1) > m * 12 + 8):
        path.append(2)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != (((x + 50) * w) / (y * z + 1) > m * 12 + 8):
        path.append(3)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((x * 50) / (y * z + 1) > m * 12 + 8):
        path.append(4)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((100 * w) / (y * z + 1) > m * 12 + 8):
        path.append(5)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((x * w) / (y * z / 1.5 + 1) > m * 12 + 8):
        path.append(6)
    if ((x * w) / (y * z + 1) > m * 12 + 8) != ((x * w) / (y * 9.1 + 1) > m * 12 + 8):
        path.append(7)
